# Copy to /etc/default/sanger16s-web or another environment file path.

SANGER16S_HOST=0.0.0.0
SANGER16S_PORT=8080
SANGER16S_DB_DIR=/opt/sanger16s/db
SANGER16S_DB_VERSION=2026-06-05
SANGER16S_PIPELINE_SCRIPT=/opt/sanger16s/run_16s_consensus_pipeline.sh
SANGER16S_WORK_DIR=/opt/sanger16s/web-work
SANGER16S_THREADS=8
SANGER16S_QUEUE_WORKERS=1
SANGER16S_MAX_TARGET_SEQS=1
SANGER16S_MAX_UPLOAD_MB=64
CONDA_ENV_NAME=sanger16s
APP_DIR=/opt/sanger16s
